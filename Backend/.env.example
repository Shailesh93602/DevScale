# ─────────────────────────────────────────────────────────────────────────────
# EduScale Backend — Environment Variables
# Copy this file to .env and fill in every value before starting the server.
# See SETUP.md (in this directory) for step-by-step instructions on where to
# obtain each key.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=4000
LOG_LEVEL=debug               # debug | info | warn | error  (use info in prod)

# Production base URL of this API (must be https:// in prod — used by Swagger + CSP)
API_URL=http://localhost:5000

# Comma-separated list of allowed frontend origins (used by CORS + Helmet CSP)
# Example: CORS_ORIGIN=https://app.eduscale.io,https://www.eduscale.io
CORS_ORIGIN=http://localhost:3000

# WebSocket server URL (usually same host as API)
WS_URL=http://localhost:5000

# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
# Pooled connection — used by Prisma at runtime (goes through PgBouncer)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection — used by Prisma migrations (bypasses PgBouncer)
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-[REGION].pooler.supabase.com:5432/postgres

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...         # anon/public key from Supabase → API Settings
SUPABASE_JWT_SIGNING_KEY=             # JWT secret from Supabase → API Settings → JWT

# ─── Redis ───────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://:[TOKEN]@[HOST]:6380
REDIS_URL=redis://localhost:6379

# ─── Cloudinary (Media CDN) ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# For development: use Mailtrap (https://mailtrap.io) — free inbox, no real delivery
# For production: use SendGrid, Resend, or AWS SES
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false               # true for port 465 (SSL), false for 587 (STARTTLS)
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EduScale <no-reply@eduscale.io>"

# Alert email — receives critical error notifications
ALERT_EMAIL=admin@eduscale.io

# Legacy mail vars (used by older parts of the codebase — set same as SMTP above)
MAIL_ADDRESS=
MAIL_PASSWORD=

# ─── Code Execution (Judge0 via RapidAPI) ────────────────────────────────────
# Sign up at https://rapidapi.com/judge0-official/api/judge0-ce
# COMPILER_CLIENT_ID  = your RapidAPI application client ID (optional header)
# COMPILER_CLIENT_SECRET = your RapidAPI key (X-RapidAPI-Key header)
COMPILER_CLIENT_ID=
COMPILER_CLIENT_SECRET=

# ─── Error Tracking (Sentry) ─────────────────────────────────────────────────
# Create a Node.js project at https://sentry.io
# Leave empty in dev to disable Sentry
SENTRY_DSN=

# ─── Auth Token Secrets ───────────────────────────────────────────────────────
# Used by legacy parts of the codebase — generate with: openssl rand -base64 64
ACCESS_TOKEN_SECRET=
RESET_TOKEN_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=15m
