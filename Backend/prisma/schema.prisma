// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id              String           @id @default(uuid())
  title           String           @db.VarChar(255)
  content         String           @db.Text
  authorId        String
  status          Status           @default(DRAFT)
  moderationNotes String?          @db.Text
  topicId         String
  resourceId      String?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  author          User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  topic           Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  resource        Resource?        @relation(fields: [resourceId], references: [id])
  versions        Version[]
  logs            SubmissionLog[]
  likes           Like[]
  comments        Comment[]
  articleVersion  ArticleVersion[] @relation("ArticleVersions")
  moderations     ContentModeration[]

  @@index([authorId])
  @@index([topicId])
}

model ArticleVersion {
  id        String   @id @default(uuid())
  articleId String
  title     String
  content   String   @db.Text
  version   Int
  createdAt DateTime @default(now())
  article   Article  @relation("ArticleVersions", fields: [articleId], references: [id])

  @@index([articleId])
}

model SubmissionLog {
  id         String   @id @default(uuid())
  authorId   String
  articleId  String
  type       String
  created_at DateTime @default(now())
  author     User     @relation(fields: [authorId], references: [id])
  article    Article  @relation(fields: [articleId], references: [id])

  @@index([authorId])
  @@index([articleId])
}

model Battle {
  id          String     @id @default(uuid())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  topicId     String
  userId      String
  difficulty  Difficulty
  length      Length
  date        DateTime?
  time        DateTime?
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  topic       Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Challenge {
  id                String                @id @default(uuid())
  title             String
  description       String                @db.Text
  points            Int
  difficulty        Difficulty
  category          ChallengeCategory
  inputFormat       String                @db.Text
  outputFormat      String                @db.Text
  exampleInput      String                @db.Text
  exampleOutput     String                @db.Text
  constraints       String                @db.Text
  functionSignature String                @db.Text
  timeLimit         Int? // in milliseconds
  memoryLimit       Int? // in MB
  tags              String[]
  testCases         TestCase[]
  solutions         Json? // Sample solutions in different languages
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt
  submissions       ChallengeSubmission[]
  topicId           String // Add this field
  topic             Topic                 @relation(fields: [topicId], references: [id]) // Add this relation
  status            ChallengeStatus       @default(PENDING)

  // @@check(points >= 0) // Ensure points are non-negative
  @@index([difficulty, points]) // Index for difficulty-based queries
  @@index([topicId]) // Add this index
}

model Chat {
  id         String   @id @default(uuid())
  message    String   @db.Text
  user1Id    String
  user2Id    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user1      User     @relation("ChatUser1", fields: [user1Id], references: [id])
  user2      User     @relation("ChatUser2", fields: [user2Id], references: [id])
}

model Course {
  id           String        @id @default(uuid())
  title        String
  description  String?       @db.Text
  instructor   String?
  duration     Int?
  level        CourseLevel?
  startDate    DateTime?
  endDate      DateTime?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  certificates Certificate[]
}

model Forum {
  id          String      @id @default(uuid())
  title       String
  description String?     @db.Text
  createdBy   String
  isActive    Boolean     @default(true)
  tags        Json?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  user        User        @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  posts       ForumPost[]
}

model InterviewQuestion {
  id         String      @id @default(uuid())
  question   String      @db.Text
  answer     String?     @db.Text
  difficulty Difficulty?
  topic      String?
  tags       Json?
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  resourceId String?
  resource   Resource?   @relation(fields: [resourceId], references: [id], onDelete: SetNull)
}

model Job {
  id                  String    @id @default(uuid())
  title               String
  description         String?   @db.Text
  company             String
  location            String?
  salary              Decimal?  @db.Decimal(10, 2)
  jobType             JobType?
  postedDate          DateTime?
  applicationDeadline DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
}

model MainConcept {
  id          String    @id @default(uuid())
  name        String
  description String    @db.Text
  roadmapId   String
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  roadmap     Roadmap   @relation(fields: [roadmapId], references: [id])
  subjects    Subject[]
}

model Quiz {
  id            String           @id @default(uuid())
  title         String
  description   String
  type          QuizType
  timeLimit     Int? // in minutes
  passingScore  Int
  questions     Question[]
  submissions   QuizSubmission[]
  quizQuestions QuizQuestion[]
  topicId       String?
  subjectId     String?
  conceptId     String?
  topic         Topic?           @relation(fields: [topicId], references: [id])
  subject       Subject?         @relation(fields: [subjectId], references: [id])
  concept       Concept?         @relation(fields: [conceptId], references: [id])
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt

  @@index([topicId])
  @@index([subjectId])
  @@index([conceptId])
}

model Question {
  id            String   @id @default(uuid())
  quizId        String
  question      String
  type          String // multiple_choice or coding
  correctAnswer String
  points        Int
  testCases     Json? // For coding questions
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  options       Option[]

  @@index([quizId])
}

model QuizAnswer {
  id          String                 @id @default(uuid())
  answer      String                 @db.Text
  isCorrect   Boolean                @default(false)
  questionId  String
  created_at  DateTime               @default(now())
  updated_at  DateTime               @updatedAt
  question    QuizQuestion           @relation(fields: [questionId], references: [id])
  submissions QuizSubmissionAnswer[]
}

model QuizOption {
  id             String       @id @default(uuid())
  answerText     String       @db.Text
  isCorrect      Boolean
  quizQuestionId String
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  quizQuestion   QuizQuestion @relation(fields: [quizQuestionId], references: [id])
}

model QuizSubmission {
  id         String                 @id @default(uuid())
  userId     String
  quizId     String
  score      Int
  timeSpent  Int // in seconds
  isPassed   Boolean
  results    Json // Array of question results
  user       User                   @relation(fields: [userId], references: [id])
  quiz       Quiz                   @relation(fields: [quizId], references: [id])
  created_at DateTime               @default(now())
  answers    QuizSubmissionAnswer[]

  @@index([userId])
  @@index([quizId])
}

model QuizSubmissionAnswer {
  id           String         @id @default(uuid())
  submissionId String
  answerId     String
  questionId   String
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  submission   QuizSubmission @relation(fields: [submissionId], references: [id])
  answer       QuizAnswer     @relation(fields: [answerId], references: [id])
  question     QuizQuestion   @relation(fields: [questionId], references: [id])
}

model QuizQuestion {
  id          String                 @id @default(uuid())
  quizId      String
  question    String
  type        String
  answers     QuizAnswer[]
  options     QuizOption[]
  submissions QuizSubmissionAnswer[]
  quiz        Quiz                   @relation(fields: [quizId], references: [id])
  created_at  DateTime               @default(now())
  updated_at  DateTime               @updatedAt

  @@index([quizId])
}

model Resource {
  id                 String              @id @default(uuid())
  title              String
  description        String              @db.Text
  type               String
  url                String
  category           String
  tags               String[]
  userId             String
  content            String?             @db.Text
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id])
  articles           Article[]
  interviewQuestions InterviewQuestion[]
  downloadCount      Int                 @default(0)
  rating             Decimal?            @db.Decimal(3, 2)
  difficulty         Difficulty
  language           String
  versions           ResourceVersion[]
  moderations        ContentModeration[]

  @@index([userId])
  @@index([category])
  @@index([type])
}

model Roadmap {
  id             String        @id @default(uuid())
  title          String
  description    String?
  topics         Topic[]
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPublic       Boolean       @default(false)
  progress       Progress[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime? // Soft delete
  mainConcepts   MainConcept[]
  concepts       Concept[]
  comments       Comment[]
  likes          Like[]
  userRoadmaps   UserRoadmap[]
  difficulty     Difficulty?
  estimatedHours Int?
  popularity     Int           @default(0)
  version        String        @default("1.0")

  @@index([userId, isPublic]) // Index for user's public roadmaps
  @@index([deletedAt]) // Index for soft delete queries
  @@index([title]) // Index for search queries
}

model Concept {
  id          String    @id @default(uuid())
  title       String
  description String
  order       Int
  roadmapId   String
  roadmap     Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  subjects    Subject[]
  quizzes     Quiz[]
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([roadmapId])
}

model Subject {
  id           String         @id @default(uuid())
  title        String
  description  String
  order        Int
  conceptId    String
  concept      Concept        @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  topics       Topic[]
  mainConcept  MainConcept[]
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  quizzes      Quiz[]
  userProgress UserProgress[]
  virtualLabs  VirtualLab[]
  placementTests PlacementTest[]

  @@index([conceptId])
}

model Topic {
  id            String         @id @default(uuid())
  title         String
  description   String
  order         Int
  content       String?
  resources     String[]
  prerequisites String[]
  subjectId     String?
  subject       Subject?        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  articles      Article[]
  quizzes       Quiz[]
  challenges    Challenge[]
  userProgress  UserProgress[]
  battles       Battle[]
  userRoadmaps  UserRoadmap[]
  studyGroups   StudyGroup[]
  dailyTopics   DailyTopic[]
  progress      Progress[]
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  roadmaps      Roadmap[]
  moderations   ContentModeration[]

  @@index([subjectId])
}

model User {
  id                        String                     @id @default(uuid())
  supabase_id               String                     @unique
  email                     String                     @unique
  username                  String                     @unique
  full_name                 String?
  avatar_url                String?
  bio                       String?
  address                   String?
  github_url                String?
  linkedin_url              String?
  twitter_url               String?
  website_url               String?
  specialization            String?
  college                   String?
  graduation_year           Int?
  skills                    String[]
  experience_level          ExperienceLevel
  created_at                DateTime                   @default(now())
  updated_at                DateTime                   @updatedAt
  status                    String?                    @default("active")
  activityLogs              ActivityLog[]
  deletedAt                 DateTime? // Add this field for soft delete
  learningPreferences       UserLearningPreference?    @relation("UserLearningPreferences")
  learningRecommendations   LearningRecommendation[]
  dailyChallengeSubmissions DailyChallengeSubmission[]
  interviewPreps            InterviewPrep[]
  skillAssessments          SkillAssessment[]
  inAppPurchases            InAppPurchase[]
  settings                  UserSettings?
  learningAnalytics         UserLearningAnalytics? // Optional 1:1 relationship
  note                      String?
  sessions                  UserSession[]
  leaderboardEntries        LeaderboardEntry[]
  auditLogs                 AuditLog[]
  is_active                 Boolean                        @default(true)

  // Relations
  articles                      Article[]
  projects                      Project[]
  teamProjects                  TeamProjectMember[]
  chatsAsUser1                  Chat[]                         @relation("ChatUser1")
  chatsAsUser2                  Chat[]                         @relation("ChatUser2")
  forums                        Forum[]
  forumPosts                    ForumPost[]
  forumComments                 ForumComment[]
  roadmaps                      Roadmap[]
  userPoints                    UserPoints?
  userProgress                  UserProgress[]
  userRoadmaps                  UserRoadmap[]
  quizSubmissions               QuizSubmission[]
  challenges                    ChallengeSubmission[]
  certificates                  Certificate[]
  notifications                 Notification[]
  studyGroups                   StudyGroupMember[]
  battles                       Battle[]
  mentorships                   Mentorship[]                   @relation("Mentor")
  mentees                       Mentorship[]                   @relation("Mentee")
  roleId                        String?
  role                          Role?                          @relation(fields: [roleId], references: [id])
  submissionLogs                SubmissionLog[]
  comments                      Comment[]
  likes                         Like[]
  achievements                  Achievement[]
  dailyTopicViews               DailyTopicView[]
  dailyTopicCompletions         DailyTopicCompletion[]
  contentReports                ContentReport[]
  moderationLogs                ModerationLog[]
  adminAuditLogs                AdminAuditLog[]
  securityAuditLogs             SecurityAuditLog[]
  changeHistory                 ChangeHistory[]
  accessLogs                    AccessLog[]
  supportTickets                SupportTicket[]                @relation("TicketCreator")
  assignedTickets               SupportTicket[]                @relation("TicketAgent")
  ticketResponses               TicketResponse[]
  bugReports                    BugReport[]
  assignedBugs                  BugReport[]                    @relation("BugAssignee")
  featureRequests               FeatureRequest[]
  featureVotes                  FeatureRequestVote[]
  apiKeys                       ApiKey[]
  ApprovalHistory               ApprovalHistory[]
  resources                     Resource[]
  githubStats                   Json?
  leetcodeStats                 Json?
  timezone                      String?
  preferredLanguage             String?
  learningStreak                Int                            @default(0)
  accessibilityPrefs            Json? // Store custom accessibility preferences
  isVerified                    Boolean                        @default(false)
  followers                     Follow[]                       @relation("FollowerRelation")
  following                     Follow[]                       @relation("FollowingRelation")
  codingSandboxes               CodingSandbox[]
  internshipApplications        InternshipApplication[]
  eventRegistrations            EventRegistration[]
  hardwareKitsSold              HardwareKit[]
  authoredCodeReviews           CodeReview[]                   @relation("CodeAuthor")
  reviewedCodeReviews           CodeReview[]                   @relation("CodeReviewer")
  collaborations                ProjectCollaboration[]
  curatedPlaylists              ContentPlaylist[]
  subscriptions                 Subscription[]
  iotDevices                    IoTDevice[]
  labSessions                   LabSession[]
  communityChallengeSubmissions CommunityChallengeSubmission[]
  UserActivityLog               UserActivityLog[]
  contents                      Content[]
  moderations                   ContentModeration[]

  @@index([roleId])
  @@index([email, username]) // Composite index for common queries
  @@index([deletedAt]) // Index for soft delete queries
}

model UserPoints {
  id         String   @id @default(uuid())
  userId     String   @unique
  points     Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model UserProgress {
  id                 String    @id @default(uuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  topicId            String?
  topic              Topic?     @relation(fields: [topicId], references: [id])
  isCompleted        Boolean   @default(false)
  completedAt        DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  timeSpent          Int? // Track time spent on each topic
  subjectId          String?
  subject            Subject?   @relation(fields: [subjectId], references: [id])
  confidenceLevel    Int?      @default(dbgenerated("NULL")) @db.SmallInt
  lastReviewed       DateTime?
  progressPercentage Int?      @default(dbgenerated("NULL")) @db.SmallInt

  @@unique([userId, topicId])
  @@index([userId])
  @@index([topicId])
}

model UserRoadmap {
  id         String   @id @default(uuid())
  isCustom   Boolean  @default(false)
  userId     String
  roadmapId  String
  topicId    String // Add this field
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  roadmap    Roadmap  @relation(fields: [roadmapId], references: [id])
  topic      Topic    @relation(fields: [topicId], references: [id]) // Add this relation

  @@unique([userId, roadmapId])
  @@index([topicId]) // Add this index
}

model Project {
  id             String                 @id @default(uuid())
  title          String
  description    String                 @db.Text
  github_url     String?
  demo_url       String?
  tech_stack     String[]
  image_url      String?
  contributors   String[] // Array of contributor names
  project_status ProjectStatus          @default(ongoing)
  visibility     Visibility             @default(public)
  userId         String
  created_at     DateTime               @default(now())
  updated_at     DateTime               @updatedAt
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  collaborations ProjectCollaboration[]
}

model TeamProject {
  id             String              @id @default(uuid())
  title          String
  description    String              @db.Text
  github_url     String?
  demo_url       String?
  tech_stack     String[]
  image_url      String?
  project_status ProjectStatus       @default(ongoing)
  visibility     Visibility          @default(public)
  created_at     DateTime            @default(now())
  updated_at     DateTime            @updatedAt
  members        TeamProjectMember[]
}

model TeamProjectMember {
  id            String      @id @default(uuid())
  userId        String
  teamProjectId String
  role          ProjectRole @default(member)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id])
  teamProject   TeamProject @relation(fields: [teamProjectId], references: [id])

  @@unique([userId, teamProjectId])
}

model ForumPost {
  id         String         @id @default(uuid())
  title      String
  content    String         @db.Text
  userId     String
  forumId    String
  tags       String[]
  upvotes    Int            @default(0)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id])
  forum      Forum          @relation(fields: [forumId], references: [id])
  comments   ForumComment[]
}

model ForumComment {
  id         String         @id @default(uuid())
  content    String         @db.Text
  userId     String
  postId     String
  parentId   String? // For nested comments
  upvotes    Int            @default(0)
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  user       User           @relation(fields: [userId], references: [id])
  post       ForumPost      @relation(fields: [postId], references: [id])
  parent     ForumComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    ForumComment[] @relation("CommentReplies")
}

model ChallengeSubmission {
  id             String           @id @default(uuid())
  challengeId    String
  userId         String
  code           String           @db.Text
  language       String
  status         SubmissionStatus
  runtime_ms     Int?
  memory_used_kb Int?
  score          Int
  feedback       String?          @db.Text
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  challenge      Challenge        @relation(fields: [challengeId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
}

model Certificate {
  id             String    @id @default(uuid())
  userId         String
  courseId       String?
  title          String
  description    String    @db.Text
  issueDate      DateTime  @default(now())
  expiryDate     DateTime?
  certificateUrl String
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])
  course         Course?   @relation(fields: [courseId], references: [id])
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  title      String
  message    String           @db.Text
  type       NotificationType
  isRead     Boolean          @default(false)
  link       String? // Optional link to redirect user
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  user       User             @relation(fields: [userId], references: [id])
}

model Mentorship {
  id          String           @id @default(uuid())
  mentorId    String
  menteeId    String
  status      MentorshipStatus @default(pending)
  topics      String[]
  description String?          @db.Text
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  mentor      User             @relation("Mentor", fields: [mentorId], references: [id])
  mentee      User             @relation("Mentee", fields: [menteeId], references: [id])
  sessions    MentorshipSession[]
  @@unique([mentorId, menteeId])
}

model StudyGroup {
  id              String               @id @default(uuid())
  name            String
  description     String               @db.Text
  topicId         String
  maxMembers      Int                  @default(5)
  isPrivate       Boolean              @default(false)
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt
  topic           Topic                @relation(fields: [topicId], references: [id])
  members         StudyGroupMember[]
  weeklyGoal      String?
  meetingSchedule String?
  sharedResources StudyGroupResource[]
}

model StudyGroupResource {
  id          String   @id @default(uuid())
  groupId     String
  title       String
  url         String
  description String   @db.Text
  created_at  DateTime @default(now())

  group StudyGroup @relation(fields: [groupId], references: [id])
}

model StudyGroupMember {
  id           String     @id @default(uuid())
  userId       String
  studyGroupId String
  role         GroupRole  @default(member)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id])
  studyGroup   StudyGroup @relation(fields: [studyGroupId], references: [id])

  @@unique([userId, studyGroupId])
}

model Comment {
  id         String    @id @default(uuid())
  content    String
  userId     String
  roadmapId  String?
  articleId  String?
  user       User      @relation(fields: [userId], references: [id])
  roadmap    Roadmap?  @relation(fields: [roadmapId], references: [id])
  article    Article?  @relation(fields: [articleId], references: [id])
  parentId   String?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    Comment[] @relation("CommentReplies")
  likes      Like[]
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([userId])
  @@index([roadmapId])
  @@index([articleId])
  @@index([parentId])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  articleId String?
  roadmapId String?
  commentId String?
  user      User     @relation(fields: [userId], references: [id])
  article   Article? @relation(fields: [articleId], references: [id])
  roadmap   Roadmap? @relation(fields: [roadmapId], references: [id])
  comment   Comment? @relation(fields: [commentId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@unique([userId, roadmapId])
  @@unique([userId, commentId])
  @@index([articleId])
  @@index([roadmapId])
  @@index([commentId])
}

model Achievement {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  description String
  criteria    Json
  earnedAt    DateTime
  created_at  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model DailyTopic {
  id          String                 @id @default(uuid())
  topicId     String
  date        DateTime
  topic       Topic                  @relation(fields: [topicId], references: [id])
  views       DailyTopicView[]
  completions DailyTopicCompletion[]
  created_at  DateTime               @default(now())

  @@unique([date])
  @@index([topicId])
}

model DailyTopicView {
  id           String     @id @default(uuid())
  userId       String
