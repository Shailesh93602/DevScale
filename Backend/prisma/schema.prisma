generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Article {
  id          String              @id @default(uuid())
  title       String              @db.VarChar(255)
  content     String
  author_id   String
  status      Status              @default(DRAFT)
  topic_id    String
  resource_id String?
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  author      User                @relation(fields: [author_id], references: [id], onDelete: Cascade)
  resource    Resource?           @relation(fields: [resource_id], references: [id])
  topic       Topic               @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  comments    Comment[]
  moderations ContentModeration[]
  likes       Like[]
  logs        SubmissionLog[]
  versions    Version[]

  @@index([author_id])
  @@index([topic_id])
}

model SubmissionLog {
  id         String   @id @default(uuid())
  author_id  String
  article_id String
  type       String
  created_at DateTime @default(now())
  article    Article  @relation(fields: [article_id], references: [id])
  author     User     @relation(fields: [author_id], references: [id])

  @@index([author_id])
  @@index([article_id])
}

model Battle {
  id                    String              @id @default(uuid())
  slug                  String?             @unique
  title                 String              @db.VarChar(255)
  description           String?
  type                  BattleType
  status                BattleStatus        @default(WAITING)
  topic_id              String?
  user_id               String
  winner_id             String?
  difficulty            Difficulty
  max_participants      Int                 @default(6)
  current_participants  Int                 @default(0)
  start_time            DateTime?
  ended_at              DateTime?
  points_per_question   Int                 @default(100)
  time_per_question     Int                 @default(30)
  total_questions       Int                 @default(10)
  question_source_type  String?
  question_source_id    String?
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt
  topic                 Topic?              @relation(fields: [topic_id], references: [id], onDelete: SetNull)
  creator               User                @relation("BattleCreator", fields: [user_id], references: [id], onDelete: Cascade)
  winner                User?               @relation("BattleWinner", fields: [winner_id], references: [id], onDelete: SetNull)
  leaderboard           BattleLeaderboard[]
  participants          BattleParticipant[]
  questions             BattleQuestion[]
  answers               BattleAnswer[]

  @@index([topic_id])
  @@index([user_id])
  @@index([winner_id])
  @@index([status])
  @@index([type])
  @@index([status, created_at])
  @@index([user_id, status])
}

model BattleParticipant {
  id                   String                  @id @default(uuid())
  battle_id            String
  user_id              String
  status               BattleParticipantStatus @default(JOINED)
  score                Int                     @default(0)
  rank                 Int?
  correct_count        Int                     @default(0)
  wrong_count          Int                     @default(0)
  avg_time_per_answer_ms Int                   @default(0)
  joined_at            DateTime                @default(now())
  completed_at         DateTime?
  last_seen_at         DateTime?
  battle               Battle                  @relation(fields: [battle_id], references: [id], onDelete: Cascade)
  user                 User                    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([battle_id, user_id])
  @@index([battle_id])
  @@index([user_id])
}

model BattleQuestion {
  id                      String         @id @default(uuid())
  battle_id               String
  question                String         @db.Text
  options                 Json
  correct_answer          Int
  explanation             String?        @db.Text
  points                  Int            @default(100)
  time_limit              Int            @default(30)
  order                   Int
  source_quiz_question_id String?
  source_challenge_id     String?
  created_at              DateTime       @default(now())
  answers                 BattleAnswer[]
  battle                  Battle         @relation(fields: [battle_id], references: [id], onDelete: Cascade)

  @@index([battle_id])
  @@index([battle_id, order])
}

model BattleAnswer {
  id              String         @id @default(uuid())
  battle_id       String
  question_id     String
  user_id         String
  selected_option Int
  is_correct      Boolean
  time_taken_ms   Int
  points_earned   Int            @default(0)
  created_at      DateTime       @default(now())
  battle          Battle         @relation(fields: [battle_id], references: [id], onDelete: Cascade)
  question        BattleQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([question_id, user_id])
  @@index([battle_id])
  @@index([battle_id, user_id])
  @@index([question_id])
  @@index([user_id])
}

model BattleLeaderboard {
  id            String   @id @default(uuid())
  battle_id     String
  user_id       String
  score         Int      @default(0)
  rank          Int
  correct_count Int      @default(0)
  total_time_ms Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  battle        Battle   @relation(fields: [battle_id], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([battle_id, user_id])
  @@index([battle_id])
  @@index([battle_id, score])
  @@index([user_id])
}

model Challenge {
  id                 String                @id @default(uuid())
  title              String                @unique
  description        String
  points             Int
  difficulty         Difficulty
  category           ChallengeCategory
  input_format       String
  output_format      String
  example_input      String
  example_output     String
  constraints        String
  function_signature String
  time_limit         Int?
  memory_limit       Int?
  tags               String[]
  company_tags       String[]
  hints              String[]
  editorial          String?
  solutions          Json?
  boilerplates       Json?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt
  topic_id           String?
  status             ChallengeStatus       @default(ACTIVE)
  topic              Topic?                @relation(fields: [topic_id], references: [id])
  submissions        ChallengeSubmission[]
  test_cases         TestCase[]
  drafts             ChallengeDraft[]

  @@index([difficulty, points])
  @@index([category])
  @@index([status])
}

model Chat {
  id         String   @id @default(uuid())
  message    String
  user1_id   String
  user2_id   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user1      User     @relation("ChatUser1", fields: [user1_id], references: [id])
  user2      User     @relation("ChatUser2", fields: [user2_id], references: [id])
}

model Course {
  id           String        @id @default(uuid())
  title        String
  description  String?
  instructor   String?
  duration     Int?
  level        CourseLevel?
  start_date   DateTime?
  end_date     DateTime?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  certificates Certificate[]
  enrollments  Enrollment[]
}

model Enrollment {
  id              String           @id @default(uuid())
  user_id         String
  course_id       String
  status          EnrollmentStatus @default(ENROLLED)
  progress        Float            @default(0)
  enrollment_date DateTime         @default(now())
  completion_date DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  course          Course           @relation(fields: [course_id], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, course_id], name: "user_id_course_id")
  @@index([user_id])
  @@index([course_id])
  @@index([user_id, status])
}

model Forum {
  id          String      @id @default(uuid())
  title       String
  description String?
  created_by  String
  is_active   Boolean     @default(true)
  tags        Json?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  user        User        @relation(fields: [created_by], references: [id], onDelete: Cascade)
  posts       ForumPost[]

  @@index([created_by])
}

model InterviewQuestion {
  id          String      @id @default(uuid())
  question    String
  answer      String?
  difficulty  Difficulty?
  topic       String?
  tags        Json?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  resource_id String?
  resource    Resource?   @relation(fields: [resource_id], references: [id])
}

model Job {
  id                   String    @id @default(uuid())
  title                String
  description          String?
  company              String
  location             String?
  salary               Decimal?  @db.Decimal(10, 2)
  job_type             JobType?
  posted_date          DateTime?
  application_deadline DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
}

model MainConcept {
  id          String               @id @default(uuid())
  slug        String?              @unique
  name        String               @unique
  description String
  created_at  DateTime             @default(now())
  updated_at  DateTime             @updatedAt
  order       Int
  subjects    MainConceptSubject[]
  quizzes     Quiz[]
  roadmaps    RoadmapMainConcept[]
}

model Quiz {
  id              String           @id @default(uuid())
  title           String
  description     String
  type            QuizType
  time_limit      Int?
  passing_score   Int
  topic_id        String?
  subject_id      String?
  main_concept_id String?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  questions       Question[]
  main_concept    MainConcept?     @relation(fields: [main_concept_id], references: [id])
  subject         Subject?         @relation(fields: [subject_id], references: [id])
  topic           Topic?           @relation(fields: [topic_id], references: [id])
  quiz_questions  QuizQuestion[]
  submissions     QuizSubmission[]

  @@index([topic_id])
  @@index([subject_id])
  @@index([main_concept_id])
}

model Question {
  id             String   @id @default(uuid())
  quiz_id        String
  question       String
  type           String
  correct_answer String
  points         Int
  test_cases     Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  options        Option[]
  quiz           Quiz     @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([quiz_id])
}

model QuizAnswer {
  id          String                 @id @default(uuid())
  answer      String
  is_correct  Boolean                @default(false)
  question_id String
  created_at  DateTime               @default(now())
  updated_at  DateTime               @updatedAt
  question    QuizQuestion           @relation(fields: [question_id], references: [id])
  submissions QuizSubmissionAnswer[]

  @@index([question_id])
}

model QuizOption {
  id               String       @id @default(uuid())
  answer_text      String
  is_correct       Boolean
  quiz_question_id String
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  quiz_question    QuizQuestion @relation(fields: [quiz_question_id], references: [id])

  @@index([quiz_question_id])
}

model QuizSubmission {
  id         String                 @id @default(uuid())
  user_id    String
  quiz_id    String
  score      Int
  time_spent Int
  is_passed  Boolean
  results    Json
  created_at DateTime               @default(now())
  quiz       Quiz                   @relation(fields: [quiz_id], references: [id])
  user       User                   @relation(fields: [user_id], references: [id])
  answers    QuizSubmissionAnswer[]

  @@index([user_id])
  @@index([quiz_id])
}

model QuizSubmissionAnswer {
  id            String         @id @default(uuid())
  submission_id String
  answer_id     String
  question_id   String
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  answer        QuizAnswer     @relation(fields: [answer_id], references: [id])
  question      QuizQuestion   @relation(fields: [question_id], references: [id])
  submission    QuizSubmission @relation(fields: [submission_id], references: [id])

  @@index([submission_id])
  @@index([answer_id])
  @@index([question_id])
}

model QuizQuestion {
  id          String                 @id @default(uuid())
  quiz_id     String
  question    String
  type        String
  created_at  DateTime               @default(now())
  updated_at  DateTime               @updatedAt
  answers     QuizAnswer[]
  options     QuizOption[]
  quiz        Quiz                   @relation(fields: [quiz_id], references: [id])
  submissions QuizSubmissionAnswer[]

  @@index([quiz_id])
}

model Resource {
  id                 String              @id @default(uuid())
  title              String
  description        String
  type               String
  url                String
  category           String
  tags               String[]
  user_id            String
  content            String?
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  downloadCount      Int                 @default(0)
  rating             Decimal?            @db.Decimal(3, 2)
  difficulty         Difficulty
  language           String
  articles           Article[]
  moderations        ContentModeration[]
  interviewQuestions InterviewQuestion[]
  user               User                @relation(fields: [user_id], references: [id])
  versions           ResourceVersion[]

  @@index([user_id])
  @@index([category])
  @@index([type])
}

model RoadmapCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  roadmaps    Roadmap[]
}

model Roadmap {
  id             String               @id @default(uuid())
  slug           String?              @unique
  title          String               @unique
  description    String?
  user_id        String
  is_public      Boolean              @default(false)
  created_at     DateTime             @default(now())
  updated_at     DateTime             @updatedAt
  deleted_at     DateTime?
  difficulty     Difficulty?
  estimatedHours Int?
  popularity     Int                  @default(0)
  version        String               @default("1.0")
  tags           String?
  category_id    String?
  comments       Comment[]
  likes          Like[]
  progress       Progress[]
  category       RoadmapCategory?     @relation(fields: [category_id], references: [id])
  user           User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  main_concepts  RoadmapMainConcept[]
  topics         RoadmapTopic[]
  user_roadmaps  UserRoadmap[]

  @@index([user_id, is_public])
  @@index([deleted_at])
  @@index([title])
  @@index([category_id])
  @@index([is_public, popularity])
}

model Subject {
  id              String               @id @default(uuid())
  slug            String?              @unique
  title           String               @unique
  description     String
  order           Int
  created_at      DateTime             @default(now())
  updated_at      DateTime             @default(now())
  main_concepts   MainConceptSubject[]
  placement_tests PlacementTest[]
  quizzes         Quiz[]
  topics          SubjectTopic[]
  user_progress   UserProgress[]
  virtual_labs    VirtualLab[]

  @@index([id])
}

model Topic {
  id            String              @id @default(uuid())
  slug          String?             @unique
  title         String
  description   String
  order         Int
  content       String?
  resources     String[]
  prerequisites String[]
  created_at    DateTime            @default(now())
  updated_at    DateTime            @default(now())
  articles      Article[]
  battles       Battle[]
  challenges    Challenge[]
  moderations   ContentModeration[]
  daily_topics  DailyTopic[]
  progress      Progress[]
  quizzes       Quiz[]
  roadmaps      RoadmapTopic[]
  study_groups  StudyGroup[]
  subjects      SubjectTopic[]
  user_progress UserProgress[]

  @@index([id])
}

model RoadmapMainConcept {
  id              String      @id @default(uuid())
  roadmap_id      String
  main_concept_id String
  order           Int
  created_at      DateTime    @default(now())
  main_concept    MainConcept @relation(fields: [main_concept_id], references: [id])
  roadmap         Roadmap     @relation(fields: [roadmap_id], references: [id])

  @@unique([roadmap_id, main_concept_id])
  @@index([roadmap_id])
  @@index([main_concept_id])
}

model MainConceptSubject {
  id              String      @id @default(uuid())
  main_concept_id String
  subject_id      String
  order           Int
  created_at      DateTime    @default(now())
  main_concept    MainConcept @relation(fields: [main_concept_id], references: [id])
  subject         Subject     @relation(fields: [subject_id], references: [id])

  @@unique([main_concept_id, subject_id])
  @@index([main_concept_id])
  @@index([subject_id])
}

model SubjectTopic {
  id         String   @id @default(uuid())
  subject_id String
  topic_id   String
  order      Int
  created_at DateTime @default(now())
  subject    Subject  @relation(fields: [subject_id], references: [id])
  topic      Topic    @relation(fields: [topic_id], references: [id])

  @@unique([subject_id, topic_id])
  @@index([subject_id])
  @@index([topic_id])
}

model RoadmapTopic {
  id         String   @id @default(uuid())
  roadmap_id String
  topic_id   String
  order      Int
  created_at DateTime @default(now())
  roadmap    Roadmap  @relation(fields: [roadmap_id], references: [id])
  topic      Topic    @relation(fields: [topic_id], references: [id])

  @@unique([roadmap_id, topic_id])
  @@index([roadmap_id])
  @@index([topic_id])
}

model User {
  id                              String                         @id @default(uuid())
  supabase_id                     String                         @unique
  email                           String                         @unique
  username                        String                         @unique
  first_name                      String?
  last_name                       String?
  avatar_url                      String?
  bio                             String?
  address                         String?
  github_url                      String?
  linkedin_url                    String?
  twitter_url                     String?
  website_url                     String?
  specialization                  String?
  college                         String?
  graduation_year                 Int?
  skills                          String[]
  experience_level                ExperienceLevel?
  created_at                      DateTime                       @default(now())
  updated_at                      DateTime                       @updatedAt
  status                          String?                        @default("active")
  deleted_at                      DateTime?
  note                            String?
  is_active                       Boolean                        @default(true)
  role_id                         String?
  github_stats                    Json?
  leetcode_stats                  Json?
  timezone                        String?
  preferred_language              String?
  learning_streak                 Int                            @default(0)
  accessibility_prefs             Json?
  is_verified                     Boolean                        @default(false)
  access_logs                     AccessLog[]
  achievements                    Achievement[]
  activityLogs                    ActivityLog[]
  admin_audit_logs                AdminAuditLog[]
  api_keys                        ApiKey[]
  approval_history                ApprovalHistory[]
  articles                        Article[]
  audit_logs                      AuditLog[]
  battles_created                 Battle[]            @relation("BattleCreator")
  battles_won                     Battle[]            @relation("BattleWinner")
  battle_answers                  BattleAnswer[]
  battle_leaderboard_entries      BattleLeaderboard[]
  battle_participations           BattleParticipant[]
  assigned_bugs                   BugReport[]                    @relation("BugAssignee")
  bug_reports                     BugReport[]
  certificates                    Certificate[]
  challenges                      ChallengeSubmission[]
  challenge_drafts                ChallengeDraft[]
  change_history                  ChangeHistory[]
  chats_as_user1                  Chat[]                         @relation("ChatUser1")
  chats_as_user2                  Chat[]                         @relation("ChatUser2")
  authored_code_reviews           CodeReview[]                   @relation("CodeAuthor")
  reviewed_code_reviews           CodeReview[]                   @relation("CodeReviewer")
  coding_sandboxes                CodingSandbox[]
  comments                        Comment[]
  community_challenge_submissions CommunityChallengeSubmission[]
  contents                        Content[]
  moderations                     ContentModeration[]
  curated_playlists               ContentPlaylist[]
  content_reports                 ContentReport[]
  daily_challenge_submissions     DailyChallengeSubmission[]
  daily_topic_completions         DailyTopicCompletion[]
  daily_topic_views               DailyTopicView[]
  enrollments                     Enrollment[]
  event_registrations             EventRegistration[]
  feature_requests                FeatureRequest[]
  feature_votes                   FeatureRequestVote[]
  followers                       Follow[]                       @relation("FollowerRelation")
  following                       Follow[]                       @relation("FollowingRelation")
  forums                          Forum[]
  forum_comments                  ForumComment[]
  forum_posts                     ForumPost[]
  hardware_kits_sold              HardwareKit[]
  in_app_purchases                InAppPurchase[]
  internship_applications         InternshipApplication[]
  interview_preps                 InterviewPrep[]
  iot_devices                     IoTDevice[]
  lab_sessions                    LabSession[]
  leaderboard_entries             LeaderboardEntry[]
  learning_recommendations        LearningRecommendation[]
  likes                           Like[]
  mentees                         Mentorship[]                   @relation("Mentee")
  mentorships                     Mentorship[]                   @relation("Mentor")
  moderation_logs                 ModerationLog[]
  notifications                   Notification[]
  projects                        Project[]
  collaborations                  ProjectCollaboration[]
  quiz_submissions                QuizSubmission[]
  resources                       Resource[]
  roadmaps                        Roadmap[]
  security_audit_logs             SecurityAuditLog[]
  skill_assessments               SkillAssessment[]
  study_groups                    StudyGroupMember[]
  submission_logs                 SubmissionLog[]
  subscriptions                   Subscription[]
  assigned_tickets                SupportTicket[]                @relation("TicketAgent")
  support_tickets                 SupportTicket[]                @relation("TicketCreator")
  team_projects                   TeamProjectMember[]
  ticket_responses                TicketResponse[]
  role                            Role?                          @relation(fields: [role_id], references: [id])
  user_activity_logs              UserActivityLog[]
  learning_analytics              UserLearningAnalytics?
  learning_preferences            UserLearningPreference?        @relation("UserLearningPreferences")
  user_points                     UserPoints?
  user_progress                   UserProgress[]
  user_roadmaps                   UserRoadmap[]
  sessions                        UserSession[]
  settings                        UserSettings?
  daily_activities                UserDailyActivity[]
  user_permissions                UserPermission[]
  user_streak                     UserStreak?

  @@index([role_id])
  @@index([email, username])
  @@index([deleted_at])
}

model UserPoints {
  id         String   @id @default(uuid())
  user_id    String   @unique
  points     Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id])
}

model UserProgress {
  id                  String    @id @default(uuid())
  user_id             String
  topic_id            String?
  is_completed        Boolean   @default(false)
  completed_at        DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  time_spent          Int?
  subject_id          String?
  confidence_level    Int?      @db.SmallInt
  last_reviewed       DateTime?
  progress_percentage Int?      @db.SmallInt
  subject             Subject?  @relation(fields: [subject_id], references: [id])
  topic               Topic?    @relation(fields: [topic_id], references: [id])
  user                User      @relation(fields: [user_id], references: [id])

  @@unique([user_id, topic_id])
  @@index([user_id])
  @@index([topic_id])
  @@index([user_id, is_completed])
}

model UserRoadmap {
  id         String   @id @default(uuid())
  is_custom  Boolean  @default(false)
  user_id    String
  roadmap_id String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  roadmap    Roadmap  @relation(fields: [roadmap_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, roadmap_id])
  @@index([user_id, created_at])
}

model Project {
  id             String                 @id @default(uuid())
  title          String
  description    String
  github_url     String?
  demo_url       String?
  tech_stack     String[]
  image_url      String?
  contributors   String[]
  project_status ProjectStatus          @default(ongoing)
  visibility     Visibility             @default(public)
  user_id        String
  created_at     DateTime               @default(now())
  updated_at     DateTime               @updatedAt
  user           User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  collaborations ProjectCollaboration[]
}

model TeamProject {
  id             String              @id @default(uuid())
  title          String
  description    String
  github_url     String?
  demo_url       String?
  tech_stack     String[]
  image_url      String?
  project_status ProjectStatus       @default(ongoing)
  visibility     Visibility          @default(public)
  created_at     DateTime            @default(now())
  updated_at     DateTime            @default(now())
  members        TeamProjectMember[]
}

model TeamProjectMember {
  id              String      @id @default(uuid())
  user_id         String
  team_project_id String
  role            ProjectRole @default(member)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @default(now())
  team_project    TeamProject @relation(fields: [team_project_id], references: [id])
  user            User        @relation(fields: [user_id], references: [id])

  @@unique([user_id, team_project_id])
}

model ForumPost {
