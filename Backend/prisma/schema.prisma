// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id          String              @id @default(uuid())
  title       String              @db.VarChar(255)
  content     String              @db.Text
  author_id   String
  status      Status              @default(DRAFT)
  topic_id    String
  resource_id String?
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  author      User                @relation(fields: [author_id], references: [id], onDelete: Cascade)
  topic       Topic               @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  resource    Resource?           @relation(fields: [resource_id], references: [id])
  versions    Version[]
  logs        SubmissionLog[]
  likes       Like[]
  comments    Comment[]
  moderations ContentModeration[]

  @@index([author_id])
  @@index([topic_id])
}

model SubmissionLog {
  id         String   @id @default(uuid())
  author_id  String
  article_id String
  type       String
  created_at DateTime @default(now())
  author     User     @relation(fields: [author_id], references: [id])
  article    Article  @relation(fields: [article_id], references: [id])

  @@index([author_id])
  @@index([article_id])
}

enum BattleType {
  INSTANT
  SCHEDULED
  TOURNAMENT
  PRACTICE
}

enum BattleStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ARCHIVED
}

model Battle {
  id                   String              @id @default(uuid())
  title                String              @db.VarChar(255)
  description          String?             @db.Text
  type                 BattleType
  status               BattleStatus        @default(UPCOMING)
  topic_id             String
  user_id              String
  difficulty           Difficulty
  length               Length
  max_participants     Int                 @default(2)
  current_participants Int                 @default(0)
  start_time           DateTime?
  end_time             DateTime?
  points_per_question  Int                 @default(10)
  time_per_question    Int                 @default(30) // in seconds
  total_questions      Int                 @default(10)
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt
  topic                Topic               @relation(fields: [topic_id], references: [id], onDelete: Cascade)
  user                 User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  participants         BattleParticipant[]
  questions            BattleQuestion[]
  leaderboard          BattleLeaderboard[]

  @@index([topic_id])
  @@index([user_id])
  @@index([status])
  @@index([type])
}

model BattleParticipant {
  id           String    @id @default(uuid())
  battle_id    String
  user_id      String
  score        Int       @default(0)
  rank         Int?
  joined_at    DateTime  @default(now())
  completed_at DateTime?
  battle       Battle    @relation(fields: [battle_id], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([battle_id, user_id])
  @@index([battle_id])
  @@index([user_id])
}

model BattleQuestion {
  id             String         @id @default(uuid())
  battle_id      String
  question       String         @db.Text
  options        Json // Array of options
  correct_answer String
  points         Int            @default(10)
  time_limit     Int            @default(30) // in seconds
  order          Int // Question order in battle
  created_at     DateTime       @default(now())
  battle         Battle         @relation(fields: [battle_id], references: [id], onDelete: Cascade)
  answers        BattleAnswer[]

  @@index([battle_id])
}

model BattleAnswer {
  id          String         @id @default(uuid())
  question_id String
  user_id     String
  answer      String
  is_correct  Boolean
  time_taken  Int // in seconds
  created_at  DateTime       @default(now())
  question    BattleQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([question_id, user_id])
  @@index([question_id])
  @@index([user_id])
}

model BattleLeaderboard {
  id         String   @id @default(uuid())
  battle_id  String
  user_id    String
  score      Int      @default(0)
  rank       Int
  time_taken Int // Total time taken in seconds
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  battle     Battle   @relation(fields: [battle_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([battle_id, user_id])
  @@index([battle_id])
  @@index([user_id])
  @@index([score])
}

model Challenge {
  id                 String                @id @default(uuid())
  title              String                @unique
  description        String                @db.Text
  points             Int
  difficulty         Difficulty
  category           ChallengeCategory
  input_format       String                @db.Text
  output_format      String                @db.Text
  example_input      String                @db.Text
  example_output     String                @db.Text
  constraints        String                @db.Text
  function_signature String                @db.Text
  time_limit         Int?
  memory_limit       Int?
  tags               String[]
  company_tags       String[]
  hints              String[]
  editorial          String?               @db.Text
  boilerplates       Json?
  test_cases         TestCase[]
  solutions          Json?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt
  submissions        ChallengeSubmission[]
  challenge_drafts   ChallengeDraft[]
  topic_id           String
  topic              Topic                 @relation(fields: [topic_id], references: [id])
  status             ChallengeStatus       @default(PENDING)

  @@index([difficulty, points])
  @@index([topic_id])
}

model Chat {
  id         String   @id @default(uuid())
  message    String   @db.Text
  user1_id   String
  user2_id   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user1      User     @relation("ChatUser1", fields: [user1_id], references: [id])
  user2      User     @relation("ChatUser2", fields: [user2_id], references: [id])
}

model Course {
  id           String        @id @default(uuid())
  title        String
  description  String?       @db.Text
  instructor   String?
  duration     Int?
  level        CourseLevel?
  start_date   DateTime?
  end_date     DateTime?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  enrollments  CourseEnrollment[]
  certificates Certificate[]
}

model Forum {
  id          String      @id @default(uuid())
  title       String
  description String?     @db.Text
  created_by  String
  is_active   Boolean     @default(true)
  tags        Json?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  user        User        @relation(fields: [created_by], references: [id], onDelete: Cascade)
  posts       ForumPost[]
}

model InterviewQuestion {
  id          String      @id @default(uuid())
  question    String      @db.Text
  answer      String?     @db.Text
  difficulty  Difficulty?
  topic       String?
  tags        Json?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  resource_id String?
  resource    Resource?   @relation(fields: [resource_id], references: [id], onDelete: SetNull)
}

model Job {
  id                   String    @id @default(uuid())
  title                String
  description          String?   @db.Text
  company              String
  location             String?
  salary               Decimal?  @db.Decimal(10, 2)
  job_type             JobType?
  posted_date          DateTime?
  application_deadline DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
}

model MainConcept {
  id          String               @id @default(uuid())
  name        String               @unique
  description String               @db.Text
  created_at  DateTime             @default(now())
  updated_at  DateTime             @updatedAt
  order       Int
  quizzes     Quiz[]
  roadmaps    RoadmapMainConcept[]
  subjects    MainConceptSubject[]
}

model Quiz {
  id              String           @id @default(uuid())
  title           String
  description     String
  type            QuizType
  time_limit      Int? // in minutes
  passing_score   Int
  questions       Question[]
  submissions     QuizSubmission[]
  quiz_questions  QuizQuestion[]
  topic_id        String?
  subject_id      String?
  main_concept_id String?
  topic           Topic?           @relation(fields: [topic_id], references: [id])
  subject         Subject?         @relation(fields: [subject_id], references: [id])
  main_concept    MainConcept?     @relation(fields: [main_concept_id], references: [id])
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  @@index([topic_id])
  @@index([subject_id])
  @@index([main_concept_id])
}

model Question {
  id             String   @id @default(uuid())
  quiz_id        String
  question       String
  type           String // multiple_choice or coding
  correct_answer String
  points         Int
  test_cases     Json? // For coding questions
  quiz           Quiz     @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  options        Option[]

  @@index([quiz_id])
}

model QuizAnswer {
  id          String                 @id @default(uuid())
  answer      String                 @db.Text
  is_correct  Boolean                @default(false)
  question_id String
  created_at  DateTime               @default(now())
  updated_at  DateTime               @updatedAt
  question    QuizQuestion           @relation(fields: [question_id], references: [id])
  submissions QuizSubmissionAnswer[]
}

model QuizOption {
  id               String       @id @default(uuid())
  answer_text      String       @db.Text
  is_correct       Boolean
  quiz_question_id String
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  quiz_question    QuizQuestion @relation(fields: [quiz_question_id], references: [id])
}

model QuizSubmission {
  id         String                 @id @default(uuid())
  user_id    String
  quiz_id    String
  score      Int
  time_spent Int // in seconds
  is_passed  Boolean
  results    Json // Array of question results
  user       User                   @relation(fields: [user_id], references: [id])
  quiz       Quiz                   @relation(fields: [quiz_id], references: [id])
  created_at DateTime               @default(now())
  answers    QuizSubmissionAnswer[]

  @@index([user_id])
  @@index([quiz_id])
}

model QuizSubmissionAnswer {
  id            String         @id @default(uuid())
  submission_id String
  answer_id     String
  question_id   String
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  submission    QuizSubmission @relation(fields: [submission_id], references: [id])
  answer        QuizAnswer     @relation(fields: [answer_id], references: [id])
  question      QuizQuestion   @relation(fields: [question_id], references: [id])
}

model QuizQuestion {
  id          String                 @id @default(uuid())
  quiz_id     String
  question    String
  type        String
  answers     QuizAnswer[]
  options     QuizOption[]
  submissions QuizSubmissionAnswer[]
  quiz        Quiz                   @relation(fields: [quiz_id], references: [id])
  created_at  DateTime               @default(now())
  updated_at  DateTime               @updatedAt

  @@index([quiz_id])
}

model Resource {
  id                 String              @id @default(uuid())
  title              String
  description        String              @db.Text
  type               String
  url                String
  category           String
  tags               String[]
  user_id            String
  content            String?             @db.Text
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  user               User                @relation(fields: [user_id], references: [id])
  articles           Article[]
  interviewQuestions InterviewQuestion[]
  downloadCount      Int                 @default(0)
  rating             Decimal?            @db.Decimal(3, 2)
  difficulty         Difficulty
  language           String
  versions           ResourceVersion[]
  moderations        ContentModeration[]

  @@index([user_id])
  @@index([category])
  @@index([type])
}

model RoadmapCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  roadmaps    Roadmap[]
}

model Roadmap {
  id             String               @id @default(uuid())
  title          String               @unique
  description    String?
  user_id        String
  user           User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  is_public      Boolean              @default(false)
  progress       Progress[]
  created_at     DateTime             @default(now())
  updated_at     DateTime             @updatedAt
  deleted_at     DateTime?
  comments       Comment[]
  likes          Like[]
  user_roadmaps  UserRoadmap[]
  difficulty     Difficulty?
  estimatedHours Int?
  popularity     Int                  @default(0)
  version        String               @default("1.0")
  main_concepts  RoadmapMainConcept[]
  topics         RoadmapTopic[]
  tags           String?
  category_id    String?
  category       RoadmapCategory?     @relation(fields: [category_id], references: [id])

  @@index([user_id, is_public])
  @@index([deleted_at])
  @@index([title])
}

model Subject {
  id              String               @id @default(uuid())
  title           String               @unique
  description     String
  order           Int
  created_at      DateTime             @default(now())
  updated_at      DateTime             @default(now())
  quizzes         Quiz[]
  user_progress   UserProgress[]
  virtual_labs    VirtualLab[]
  placement_tests PlacementTest[]
  main_concepts   MainConceptSubject[]
  topics          SubjectTopic[]

  @@index([id])
}

model Topic {
  id            String              @id @default(uuid())
  title         String
  description   String
  order         Int
  content       String?
  resources     String[]
  prerequisites String[]
  created_at    DateTime            @default(now())
  updated_at    DateTime            @default(now())
  articles      Article[]
  quizzes       Quiz[]
  challenges    Challenge[]
  user_progress UserProgress[]
  battles       Battle[]
  study_groups  StudyGroup[]
  daily_topics  DailyTopic[]
  progress      Progress[]
  moderations   ContentModeration[]
  subjects      SubjectTopic[]
  roadmaps      RoadmapTopic[]

  @@index([id])
}

// Junction Tables
model RoadmapMainConcept {
  id              String      @id @default(uuid())
  roadmap_id      String
  main_concept_id String
  order           Int
  created_at      DateTime    @default(now())
  roadmap         Roadmap     @relation(fields: [roadmap_id], references: [id])
  main_concept    MainConcept @relation(fields: [main_concept_id], references: [id])

  @@unique([roadmap_id, main_concept_id])
  @@index([roadmap_id])
  @@index([main_concept_id])
}

model MainConceptSubject {
  id              String      @id @default(uuid())
  main_concept_id String
  subject_id      String
  order           Int
  created_at      DateTime    @default(now())
  main_concept    MainConcept @relation(fields: [main_concept_id], references: [id])
  subject         Subject     @relation(fields: [subject_id], references: [id])

  @@unique([main_concept_id, subject_id])
  @@index([main_concept_id])
  @@index([subject_id])
}

model SubjectTopic {
  id         String   @id @default(uuid())
  subject_id String
  topic_id   String
  order      Int
  created_at DateTime @default(now())
  subject    Subject  @relation(fields: [subject_id], references: [id])
  topic      Topic    @relation(fields: [topic_id], references: [id])

  @@unique([subject_id, topic_id])
  @@index([subject_id])
  @@index([topic_id])
}

model RoadmapTopic {
  id         String   @id @default(uuid())
  roadmap_id String
  topic_id   String
  order      Int
  created_at DateTime @default(now())
  roadmap    Roadmap  @relation(fields: [roadmap_id], references: [id])
  topic      Topic    @relation(fields: [topic_id], references: [id])

  @@unique([roadmap_id, topic_id])
  @@index([roadmap_id])
  @@index([topic_id])
}

model User {
  id                          String                     @id @default(uuid())
  supabase_id                 String                     @unique
  email                       String                     @unique
  username                    String                     @unique
  full_name                   String?
  avatar_url                  String?
  bio                         String?
  address                     String?
  github_url                  String?
  linkedin_url                String?
  twitter_url                 String?
  website_url                 String?
  specialization              String?
  college                     String?
  graduation_year             Int?
  skills                      String[]
  experience_level            ExperienceLevel?
  created_at                  DateTime                   @default(now())
  updated_at                  DateTime                   @updatedAt
  status                      String?                    @default("active")
  activityLogs                ActivityLog[]
  deleted_at                  DateTime? // Add this field for soft delete
  learning_preferences        UserLearningPreference?    @relation("UserLearningPreferences")
  learning_recommendations    LearningRecommendation[]
  daily_challenge_submissions DailyChallengeSubmission[]
  interview_preps             InterviewPrep[]
  skill_assessments           SkillAssessment[]
  in_app_purchases            InAppPurchase[]
  settings                    UserSettings?
  learning_analytics          UserLearningAnalytics? // Optional 1:1 relationship
  note                        String?
  sessions                    UserSession[]
  leaderboard_entries         LeaderboardEntry[]
  audit_logs                  AuditLog[]
  is_active                   Boolean                    @default(true)
  user_permissions            UserPermission[]

  // Relations
  articles                        Article[]
  projects                        Project[]
  team_projects                   TeamProjectMember[]
  chats_as_user1                  Chat[]                         @relation("ChatUser1")
  chats_as_user2                  Chat[]                         @relation("ChatUser2")
  forums                          Forum[]
  forum_posts                     ForumPost[]
  forum_comments                  ForumComment[]
  roadmaps                        Roadmap[]
  user_points                     UserPoints?
  user_progress                   UserProgress[]
  user_roadmaps                   UserRoadmap[]
  quiz_submissions                QuizSubmission[]
  challenges                      ChallengeSubmission[]
  certificates                    Certificate[]
  notifications                   Notification[]
  study_groups                    StudyGroupMember[]
  battles                         Battle[]
  battle_participations           BattleParticipant[]
  battle_answers                  BattleAnswer[]
  battle_leaderboard_entries      BattleLeaderboard[]
  mentorships                     Mentorship[]                   @relation("Mentor")
  mentees                         Mentorship[]                   @relation("Mentee")
  role_id                         String?
  role                            Role?                          @relation(fields: [role_id], references: [id])
  submission_logs                 SubmissionLog[]
  comments                        Comment[]
  likes                           Like[]
  achievements                    Achievement[]
  daily_topic_views               DailyTopicView[]
  daily_topic_completions         DailyTopicCompletion[]
  content_reports                 ContentReport[]
  moderation_logs                 ModerationLog[]
  admin_audit_logs                AdminAuditLog[]
  security_audit_logs             SecurityAuditLog[]
  change_history                  ChangeHistory[]
  access_logs                     AccessLog[]
  support_tickets                 SupportTicket[]                @relation("TicketCreator")
  assigned_tickets                SupportTicket[]                @relation("TicketAgent")
  ticket_responses                TicketResponse[]
  bug_reports                     BugReport[]
  assigned_bugs                   BugReport[]                    @relation("BugAssignee")
  feature_requests                FeatureRequest[]
  feature_votes                   FeatureRequestVote[]
  api_keys                        ApiKey[]
  approval_history                ApprovalHistory[]
  resources                       Resource[]
  github_stats                    Json?
  leetcode_stats                  Json?
  timezone                        String?
  preferred_language              String?
  learning_streak                 Int                            @default(0)
  accessibility_prefs             Json? // Store custom accessibility preferences
  is_verified                     Boolean                        @default(false)
  followers                       Follow[]                       @relation("FollowerRelation")
  following                       Follow[]                       @relation("FollowingRelation")
  coding_sandboxes                CodingSandbox[]
  internship_applications         InternshipApplication[]
  event_registrations             EventRegistration[]
  hardware_kits_sold              HardwareKit[]
  authored_code_reviews           CodeReview[]                   @relation("CodeAuthor")
  reviewed_code_reviews           CodeReview[]                   @relation("CodeReviewer")
  collaborations                  ProjectCollaboration[]
  curated_playlists               ContentPlaylist[]
  subscriptions                   Subscription[]
  iot_devices                     IoTDevice[]
  lab_sessions                    LabSession[]
  community_challenge_submissions CommunityChallengeSubmission[]
  course_enrollments              CourseEnrollment[]
  user_activity_logs              UserActivityLog[]
  contents                        Content[]
  moderations                     ContentModeration[]
  challenge_drafts                ChallengeDraft[]
  user_streak                     UserStreak?
  daily_activities                UserDailyActivity[]

  @@index([role_id])
  @@index([email, username]) // Composite index for common queries
  @@index([deleted_at]) // Index for soft delete queries
}

model UserPoints {
  id         String   @id @default(uuid())
  user_id    String   @unique
  points     Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id])
}

model UserProgress {
  id                  String    @id @default(uuid())
  user_id             String
  user                User      @relation(fields: [user_id], references: [id])
  topic_id            String?
  topic               Topic?    @relation(fields: [topic_id], references: [id])
  is_completed        Boolean   @default(false)
  completed_at        DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  time_spent          Int? // Track time spent on each topic
  subject_id          String?
  subject             Subject?  @relation(fields: [subject_id], references: [id])
  confidence_level    Int?      @default(dbgenerated("NULL")) @db.SmallInt
  last_reviewed       DateTime?
  progress_percentage Int?      @default(dbgenerated("NULL")) @db.SmallInt

  @@unique([user_id, topic_id])
  @@index([user_id])
  @@index([topic_id])
}

model UserRoadmap {
  id         String   @id @default(uuid())
  is_custom  Boolean  @default(false)
  user_id    String
  roadmap_id String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id])
  roadmap    Roadmap  @relation(fields: [roadmap_id], references: [id])

  @@unique([user_id, roadmap_id])
}

model Project {
  id             String                 @id @default(uuid())
  title          String
  description    String                 @db.Text
  github_url     String?
  demo_url       String?
  tech_stack     String[]
  image_url      String?
  contributors   String[] // Array of contributor names
  project_status ProjectStatus          @default(ongoing)
  visibility     Visibility             @default(public)
  user_id        String
  created_at     DateTime               @default(now())
  updated_at     DateTime               @updatedAt
  user           User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  collaborations ProjectCollaboration[]
}

model TeamProject {
  id             String              @id @default(uuid())
  title          String
  description    String              @db.Text
  github_url     String?
  demo_url       String?
  tech_stack     String[]
  image_url      String?
  project_status ProjectStatus       @default(ongoing)
  visibility     Visibility          @default(public)
  created_at     DateTime            @default(now())
  updated_at     DateTime            @default(now())
  members        TeamProjectMember[]
}

model TeamProjectMember {
  id              String      @id @default(uuid())
  user_id         String
  team_project_id String
  role            ProjectRole @default(member)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @default(now())
  user            User        @relation(fields: [user_id], references: [id])
  team_project    TeamProject @relation(fields: [team_project_id], references: [id])

  @@unique([user_id, team_project_id])
}

model ForumPost {
  id         String         @id @default(uuid())
  title      String
  content    String         @db.Text
  user_id    String
  forum_id   String
  tags       String[]
  upvotes    Int            @default(0)
  created_at DateTime       @default(now())
  updated_at DateTime       @default(now())
  user       User           @relation(fields: [user_id], references: [id])
  forum      Forum          @relation(fields: [forum_id], references: [id])
  comments   ForumComment[]
}

model ForumComment {
  id         String         @id @default(uuid())
  content    String         @db.Text
  user_id    String
  post_id    String
  parent_id  String? // For nested comments
  upvotes    Int            @default(0)
  created_at DateTime       @default(now())
  updated_at DateTime       @default(now())
  user       User           @relation(fields: [user_id], references: [id])
  post       ForumPost      @relation(fields: [post_id], references: [id])
  parent     ForumComment?  @relation("CommentReplies", fields: [parent_id], references: [id])
  replies    ForumComment[] @relation("CommentReplies")
}

model ChallengeSubmission {
  id             String           @id @default(uuid())
  challenge_id   String
  user_id        String
  code           String           @db.Text
  language       String
  status         SubmissionStatus
  runtime_ms     Int?
