  amount     Decimal  @db.Decimal(10, 2)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])
}

model UserSettings {
  id            String   @id @default(uuid())
  user_id       String   @unique
  language      String   @default("en")
  theme         String   @default("light")
  text_size     Int      @default(16)
  high_contrast Boolean  @default(false)
  created_at    DateTime @default(now())
  user          User     @relation(fields: [user_id], references: [id])
}

model TranslatedContent {
  id          String   @id @default(uuid())
  original_id String
  language    String
  content     String   @db.Text
  created_at  DateTime @default(now())

  @@unique([original_id, language])
}

model UserLearningAnalytics {
  id           String   @id @default(uuid())
  user_id      String   @unique
  weekly_hours Json // {week: "2024-01", hours: 12}
  strengths    String[]
  weaknesses   String[]
  created_at   DateTime @default(now())
  user         User     @relation(fields: [user_id], references: [id])
}

model AdminDashboard {
  id           String   @id @default(uuid())
  metrics      Json // {active_users: 1500, completion_rate: 65%}
  generated_at DateTime @default(now())
}

model IoTDevice {
  id           String       @id @default(uuid())
  user_id      String
  device_type  String // arduino/raspberry-pi/sensor
  identifier   String
  last_seen    DateTime
  created_at   DateTime     @default(now())
  user         User         @relation(fields: [user_id], references: [id])
  lab_sessions LabSession[]
}

model LabSession {
  id          String    @id @default(uuid())
  user_id     String
  device_id   String
  sensor_data Json
  start_time  DateTime
  end_time    DateTime
  created_at  DateTime  @default(now())
  user        User      @relation(fields: [user_id], references: [id])
  device      IoTDevice @relation(fields: [device_id], references: [id])
}

model CommunityChallenge {
  id          String                         @id @default(uuid())
  title       String
  description String                         @db.Text
  reward      String // badges/points/real prizes
  start_date  DateTime
  end_date    DateTime
  created_at  DateTime                       @default(now())
  submissions CommunityChallengeSubmission[]
}

model AutomatedModeration {
  id           String   @id @default(uuid())
  content_id   String
  content_type String
  decision     String // approved/rejected/flagged
  confidence   Decimal  @db.Decimal(3, 2)
  created_at   DateTime @default(now())
}

model CommunityChallengeSubmission {
  id           String   @id @default(uuid())
  challenge_id String
  user_id      String
  content      String   @db.Text
  status       String   @default("pending")
  created_at   DateTime @default(now())

  challenge CommunityChallenge @relation(fields: [challenge_id], references: [id])
  user      User               @relation(fields: [user_id], references: [id])

  @@index([challenge_id])
  @@index([user_id])
}

model ActivityLog {
  id          String     @id @default(uuid())
  user_id     String
  activity    String
  metadata    Json?
  timestamp   DateTime   @default(now())
  device_type DeviceType @default(WEB)
  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([timestamp])
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  parent_id   String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children    Category[] @relation("CategoryHierarchy")
}

model MentorshipSession {
  id            String     @id @default(uuid())
  date          DateTime
  duration      Int
  notes         String?
  objectives    Json?
  mentorship    Mentorship @relation(fields: [mentorship_id], references: [id])
  mentorship_id String
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
}

model ErrorLog {
  id        String   @id @default(uuid())
  message   String
  service   String
  timestamp DateTime @default(now())
}

model UserSession {
  id         String    @id @default(uuid())
  user_id    String
  user       User      @relation(fields: [user_id], references: [id])
  start_time DateTime
  end_time   DateTime?
  device     String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([user_id])
}

model Option {
  id          String   @id @default(uuid())
  text        String
  is_correct  Boolean
  question_id String
  question    Question @relation(fields: [question_id], references: [id])
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model PlacementTest {
  id         String          @id @default(uuid())
  user_id    String
  subject_id String
  status     PlacementStatus @default(PENDING)
  results    Json?
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  subject    Subject         @relation(fields: [subject_id], references: [id])

  @@index([user_id])
  @@index([subject_id])
}

model PlacementBook {
  id          String   @id @default(uuid())
  title       String
  description String
  level       String
  subject_id  String
  file_path   String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([subject_id])
  @@index([level])
}

model LeaderboardEntry {
  id         String   @id @default(uuid())
  user_id    String
  score      Int
  subject_id String
  time_taken Int // in seconds
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id])

  @@index([subject_id])
  @@index([score])
  @@index([time_taken])
}

