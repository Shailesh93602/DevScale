model AuditLog {
  id        String   @id @default(uuid())
  action    String
  user_id   String
  user      User     @relation(fields: [user_id], references: [id])
  timestamp DateTime @default(now())
  details   Json

  @@index([user_id])
  @@index([timestamp])
}

model Content {
  id          String              @id @default(uuid())
  title       String
  body        String
  status      ContentStatus       @default(PENDING_REVIEW)
  author_id   String
  author      User                @relation(fields: [author_id], references: [id])
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  moderations ContentModeration[]

  @@index([author_id])
  @@index([status])
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

model ContentModeration {
  id           String    @id @default(uuid())
  content_type String
  action       String
  notes        String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  moderator    User      @relation(fields: [moderator_id], references: [id])
  moderator_id String
  content      Content?  @relation(fields: [content_id], references: [id])
  content_id   String?
  topic        Topic?    @relation(fields: [topic_id], references: [id])
  topic_id     String?
  article      Article?  @relation(fields: [article_id], references: [id])
  article_id   String?
  resource     Resource? @relation(fields: [resource_id], references: [id])
  resource_id  String?

  @@index([content_id])
  @@index([article_id])
  @@index([resource_id])
  @@index([moderator_id])
}

enum ActivityType {
  TOPIC_COMPLETION
  QUIZ_COMPLETION
  CODE_CHALLENGE
  RESOURCE_STUDY
  PRACTICE_SESSION
}

model UserStreak {
  id                 String              @id @default(uuid())
  user_id            String              @unique
  current_streak     Int                 @default(0)
  longest_streak     Int                 @default(0)
  last_activity_date DateTime?
  streak_start_date  DateTime?
  timezone           String              @default("UTC")
  user               User                @relation(fields: [user_id], references: [id], map: "user_streaks_user_id_fkey")
  daily_activities   UserDailyActivity[]

  @@map("user_streaks")
}

model UserDailyActivity {
  id            String       @id @default(uuid())
  user_id       String
  activity_type ActivityType
  minutes_spent Int
  created_at    DateTime     @default(now())
  user          User         @relation(fields: [user_id], references: [id], map: "user_daily_activities_user_id_fkey")
  streak        UserStreak   @relation(fields: [user_id], references: [user_id], map: "user_daily_activities_streak_id_fkey")

  @@map("user_daily_activities")
}
