            "question": "What is the difference between Event Time and Processing Time in stream processing?",
            "points": 10,
            "options": [
                {
                    "text": "Event Time is when the source produced the event; Processing Time is when the cluster executes the event.",
                    "isCorrect": true
                },
                {
                    "text": "Event Time measures latency; Processing Time measures throughput.",
                    "isCorrect": false
                },
                {
                    "text": "Event Time only supports batch jobs; Processing Time supports streams.",
                    "isCorrect": false
                },
                {
                    "text": "They operate identically but run on different nodes.",
                    "isCorrect": false
                }
            ]
        },
