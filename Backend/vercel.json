{
  "version": 2,
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/health",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/health",
      "schedule": "0 15 * * *"
    }
  ]
}