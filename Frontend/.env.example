# ─────────────────────────────────────────────────────────────────────────────
# EduScale Frontend — Environment Variables
# Copy this file to .env.local and fill in every value.
# See SETUP.md (in the repo root) for step-by-step instructions.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...    # anon/public key — Supabase → API Settings

# ─── Backend API ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1
# Production example: NEXT_PUBLIC_API_BASE_URL=https://api.eduscale.io/api/v1

# ─── WebSocket ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=http://localhost:5000
# Production example: NEXT_PUBLIC_WS_URL=https://api.eduscale.io

# ─── Error Tracking (Sentry) ─────────────────────────────────────────────────
# Create a Next.js project at https://sentry.io
# Leave empty in dev to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=
